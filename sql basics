SELECT m.nom, COUNT(c.id) AS nb_categories
FROM materiel m
JOIN categorie_materiel cat_m ON m.id = cat_m.id_materiel
JOIN categorie c ON cat_m.id_categorie = c.id
GROUP BY m.id, m.nom
HAVING COUNT(c.id) > 1;
