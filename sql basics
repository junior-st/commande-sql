SELECT c.nom, c.prenom,
       COALESCE(SUM(m.prix), 0) AS total_depense
FROM client c
LEFT JOIN location l ON c.id = l.id_client
LEFT JOIN location_materiel lm ON l.id = lm.id_location
LEFT JOIN materiel m ON lm.id_materiel = m.id
GROUP BY c.id, c.nom, c.prenom;

